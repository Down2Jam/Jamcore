# Local development and docker compose defaults.
# Copy this file to .env and replace secrets before running the app.

NODE_ENV=development
DOCKER_TARGET=dev
PORT=3005
FRONT_DEV_PORT=3000
CLIENT_ORIGIN=http://localhost:3000
FEDERATION_ORIGIN=http://localhost:3005
RUNTIME_ROLE=all

POSTGRES_USER=jammer
POSTGRES_PASSWORD=change-me-local-password
POSTGRES_DB=jamcore
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5440/${POSTGRES_DB}

CACHE_PROVIDER=memory
RATE_LIMIT_PROVIDER=memory
# REDIS_URL=redis://redis:6379

TOKEN_SECRET=change-me-local-token-secret
# SERVICE_API_KEYS=local-service-key
# APP_CONFIG_PATH=./config/app.local.json

# Optional Cloudflare R2/S3-compatible storage for uploads.
# R2_ENDPOINT=https://account-id.r2.cloudflarestorage.com
# R2_BUCKET_NAME=jamcore-dev
# AWS_ACCESS_KEY_ID=change-me
# AWS_SECRET_ACCESS_KEY=change-me
