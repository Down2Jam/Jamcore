{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "rootDir": ".",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@features/*": ["features/*"],
      "@infra/*": ["infra/*"],
      "@loaders/*": ["loaders/*"],
      "@lib/*": ["lib/*"],
      "@middleware/*": ["middleware/*"],
      "@guards/*": ["guards/*"],
      "@types/*": ["types/*"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
