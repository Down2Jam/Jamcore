// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  slug              String   @unique
  name              String
  email             String?
  password          String
  profilePicture    String?
  bannerPicture     String?
  profileBackground String?
  short             String?
  bio               String?
  pronouns          String?
  links             String[] @default([])
  linkLabels        String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  mod               Boolean  @default(false)
  admin             Boolean  @default(false)
  twitch            String?
  tenantId          String?  @map("tenant_id")

  // Relations
  posts                         Post[]                  @relation(name: "PostToAuthor")
  likes                         Like[]
  comments                      Comment[]
  jams                          Jam[]
  reports                       Report[]                @relation(name: "ReportToUser")
  createdReports                Report[]                @relation(name: "ReportToReporter")
  assignedReports               Report[]                @relation(name: "ReportToAssignee")
  themeSuggestions              ThemeSuggestion[]       @relation(name: "SuggestionToUser")
  themeVotes                    ThemeVote[]             @relation(name: "VoteToUser")
  themeVotes2                   ThemeVote2[]            @relation(name: "Vote2ToUser")
  gamePageTracks                GamePageTrack[]         @relation(name: "GamePageTrackToComposer")
  gamePageTrackCredits          GamePageTrackCredit[]   @relation(name: "GamePageTrackCreditToUser")
  trackTimestampComments        TrackTimestampComment[] @relation(name: "TrackTimestampCommentToAuthor")
  scores                        Score[]                 @relation(name: "ScoreToUser")
  ghosts                        Ghost[]                 @relation(name: "GhostToUser")
  data                          Data[]                  @relation(name: "DataToUser")
  events                        Event[]
  primaryRoles                  TeamRole[]              @relation(name: "PrimaryRolesToUsers")
  secondaryRoles                TeamRole[]              @relation(name: "SecondaryRolesToUsers")
  teams                         Team[]
  ownedTeams                    Team[]                  @relation(name: "TeamsToOwner")
  teamApplications              TeamApplication[]       @relation(name: "TeamApplicationsToUser")
  teamInvites                   TeamInvite[]            @relation(name: "TeamInvitesToUser")
  ratings                       Rating[]                @relation(name: "RatingToUser")
  trackRatings                  TrackRating[]           @relation(name: "TrackRatingToUser")
  commentReactions              CommentReaction[]
  gamePageAchievements          GamePageAchievement[]   @relation(name: "GamePageAchievementToUsers")
  receivedNotifications         Notification[]          @relation(name: "NotificationToRecipient")
  sentNotifications             Notification[]          @relation(name: "NotificationToActor")
  PostReaction                  PostReaction[]
  reactionsAuthored             Reaction[]              @relation(name: "ReactionToArtist")
  emotePrefix                   String?
  userEmotes                    Reaction[]              @relation(name: "ReactionToUserOwner")
  reactionsUploaded             Reaction[]              @relation(name: "ReactionToUploader")
  recommendedGames              Game[]                  @relation(name: "UserRecommendedGames")
  recommendedPosts              Post[]                  @relation(name: "UserRecommendedPosts")
  recommendedTracks             GamePageTrack[]         @relation(name: "UserRecommendedTracks")
  documentationDocuments        DocumentationDocument[]
  pressKitMedia                 PressKitMedia[]
  recommendedGameOverrideIds    Int[]                   @default([])
  recommendedGameHiddenIds      Int[]                   @default([])
  recommendedTrackOverrideIds   Int[]                   @default([])
  recommendedTrackHiddenIds     Int[]                   @default([])
  hideRatings                   Boolean                 @default(false)
  autoHideRatingsWhileStreaming Boolean                 @default(false)

  @@index([tenantId])
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum PageVersion {
  JAM
  POST_JAM
}

model TagCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  tags Tag[]
}

model Tag {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  autoRegex   String?
  alwaysAdded Boolean  @default(false)
  priority    Priority @default(MEDIUM)
  modOnly     Boolean  @default(false)
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gameTag     Boolean  @default(true)
  postTag     Boolean  @default(true)

  // Relations
  posts      Post[]
  games      Game[]       @relation(name: "GamesToTags")
  gamePages  GamePage[]   @relation(name: "GamePagesToTags")
  category   TagCategory? @relation(fields: [categoryId], references: [id])
  categoryId Int?
}

model CustomTag {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts Post[]
}

model Post {
  id                 Int       @id @default(autoincrement())
  slug               String?   @unique
  title              String
  content            String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  editedAt           DateTime?
  deletedAt          DateTime?
  removedAt          DateTime?
  sticky             Boolean   @default(false)
  draftStatus        String    @default("published") @map("draft_status")
  scheduledPublishAt DateTime? @map("scheduled_publish_at")
  previewToken       String?   @map("preview_token")
  tenantId           String?   @map("tenant_id")

  // Relations
  author             User           @relation(fields: [authorId], references: [id], name: "PostToAuthor")
  authorId           Int
  tags               Tag[]
  customTags         CustomTag[]
  comments           Comment[]
  likes              Like[]         @relation(name: "LikeToPost")
  reports            Report[]       @relation(name: "ReportToPost")
  reactions          Reaction[]     @relation(name: "PostToReactions")
  postReactions      PostReaction[]
  notifications      Notification[] @relation(name: "post")
  recommendedByUsers User[]         @relation(name: "UserRecommendedPosts")

  @@index([tenantId, createdAt])
}

enum DocumentationSection {
  DOCS
  PRESS_KIT
}

model DocumentationDocument {
  id        Int                  @id @default(autoincrement())
  slug      String               @unique
  title     String
  content   String
  icon      String               @default("book")
  order     Int                  @default(0)
  section   DocumentationSection
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  editedAt  DateTime?

  author   User @relation(fields: [authorId], references: [id])
  authorId Int
}

model PressKitMedia {
  id        Int      @id @default(autoincrement())
  image     String
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User @relation(fields: [authorId], references: [id])
  authorId Int
}

enum ReactionScope {
  GLOBAL
  USER
  GAME
}

model Reaction {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  image       String
  artist      String?
  artistId    Int?
  uploaderId  Int?
  scopeType   ReactionScope @default(GLOBAL)
  scopeUserId Int?
  scopeGameId Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  artistUser       User?             @relation(fields: [artistId], references: [id], name: "ReactionToArtist")
  uploaderUser     User?             @relation(fields: [uploaderId], references: [id], name: "ReactionToUploader")
  ownerUser        User?             @relation(fields: [scopeUserId], references: [id], name: "ReactionToUserOwner")
  ownerGame        Game?             @relation(fields: [scopeGameId], references: [id], name: "ReactionToGameOwner")
  posts            Post[]            @relation(name: "PostToReactions")
  postReactions    PostReaction[]
  commentReactions CommentReaction[]
}

model PostReaction {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  // Relations
  post       Post     @relation(fields: [postId], references: [id])
  postId     Int
  reaction   Reaction @relation(fields: [reactionId], references: [id])
  reactionId Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  @@unique([postId, reactionId, userId])
}

model CommentReaction {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  comment    Comment  @relation(fields: [commentId], references: [id])
  commentId  Int
  reaction   Reaction @relation(fields: [reactionId], references: [id])
  reactionId Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  @@unique([commentId, reactionId, userId])
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?
  deletedAt DateTime?
  removedAt DateTime?

  // Relations
  post             Post?             @relation(fields: [postId], references: [id])
  postId           Int?
  comment          Comment?          @relation(fields: [commentId], references: [id], name: "CommentToComments")
  commentId        Int?
  game             Game?             @relation(fields: [gameId], references: [id], name: "CommentToGame")
  gameId           Int?
  gamePage         GamePage?         @relation(fields: [gamePageId], references: [id], name: "CommentToGamePage")
  gamePageId       Int?
  track            GamePageTrack?    @relation(fields: [trackId], references: [id], name: "CommentToTrack")
  trackId          Int?
  author           User              @relation(fields: [authorId], references: [id])
  authorId         Int
  likes            Like[]            @relation(name: "LikeToComment")
  commentReactions CommentReaction[]
  reports          Report[]          @relation(name: "ReportToComment")
  children         Comment[]         @relation(name: "CommentToComments")
  notifications    Notification[]    @relation(name: "NotificationToComment")
}

model Jam {
  id                     Int      @id @default(autoincrement())
  name                   String
  slug                   String   @unique
  startTime              DateTime @default(now())
  suggestionHours        Int      @default(168)
  slaughterHours         Int      @default(96)
  votingHours            Int      @default(72)
  jammingHours           Int      @default(72)
  ratingHours            Int      @default(334)
  submissionHours        Int      @default(2)
  postJamRefinementHours Int      @default(336)
  postJamRatingHours     Int      @default(336)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  themePerUser           Int      @default(3)
  themePerRound          Int      @default(15)
  noOfRounds             Int      @default(1)
  icon                   String?
  color                  String?
  tenantId               String?  @map("tenant_id")

  // Relations
  games            Game[]            @relation(name: "GameToJam")
  users            User[]
  themeSuggestions ThemeSuggestion[] @relation(name: "SuggestionToJam")
  themeVotes       ThemeVote[]       @relation(name: "VoteToJam")
  themeVotes2      ThemeVote2[]      @relation(name: "Vote2ToJam")
  teams            Team[]            @relation(name: "TeamsToJam")

  @@index([tenantId, startTime])
}

model Event {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  startTime DateTime
  endTime   DateTime
  link      String?
  icon      String?

  // Relations
  category   EventCategory @relation(fields: [categoryId], references: [id])
  categoryId Int
  host       User          @relation(fields: [hostId], references: [id])
  hostId     Int
}

model EventCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  events Event[]
}

enum GameCategory {
  REGULAR
  ODA
  EXTRA
}

model Game {
  id                  Int              @id @default(autoincrement())
  slug                String           @unique
  category            GameCategory
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  ratingCategories    RatingCategory[]
  majRatingCategories RatingCategory[] @relation(name: "GameToMajorityContentRating")
  published           Boolean          @default(false)
  tenantId            String?          @map("tenant_id")

  // Relations
  team               Team               @relation(fields: [teamId], references: [id], name: "GameToTeam")
  teamId             Int                @unique
  jam                Jam                @relation(fields: [jamId], references: [id], name: "GameToJam")
  jamId              Int
  reports            Report[]           @relation(name: "ReportToGame")
  downloadLinks      GameDownloadLink[] @relation(name: "LinkToGame")
  ratings            Rating[]           @relation(name: "RatingToGame")
  flags              Flag[]             @relation(name: "GamesToFlags")
  tags               Tag[]              @relation(name: "GamesToTags")
  comments           Comment[]          @relation(name: "CommentToGame")
  notifications      Notification[]     @relation(name: "NotificationToGame")
  gameEmotes         Reaction[]         @relation(name: "ReactionToGameOwner")
  recommendedByUsers User[]             @relation(name: "UserRecommendedGames")
  pages              GamePage[]         @relation(name: "GameToPages")

  @@index([tenantId, jamId])
}

model GamePage {
  id                   Int         @id @default(autoincrement())
  version              PageVersion
  name                 String
  description          String?
  short                String?
  thumbnail            String?
  banner               String?
  screenshots          String[]    @default([])
  trailerUrl           String?
  itchEmbedUrl         String?
  itchEmbedAspectRatio String?
  inputMethods         String[]    @default([])
  estOneRun            String?
  estAnyPercent        String?
  estHundredPercent    String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  themeJustification   String?
  emotePrefix          String?

  game                Game                   @relation(fields: [gameId], references: [id], name: "GameToPages")
  gameId              Int
  ratingCategories    RatingCategory[]
  majRatingCategories RatingCategory[]       @relation(name: "GamePageToMajorityContentRating")
  flags               Flag[]                 @relation(name: "GamePagesToFlags")
  tags                Tag[]                  @relation(name: "GamePagesToTags")
  downloadLinks       GamePageDownloadLink[] @relation(name: "LinkToGamePage")
  tracks              GamePageTrack[]        @relation(name: "TrackToGamePage")
  leaderboards        GamePageLeaderboard[]  @relation(name: "LeaderboardToGamePage")
  achievements        GamePageAchievement[]  @relation(name: "AchievementToGamePage")
  comments            Comment[]              @relation(name: "CommentToGamePage")
  ghosts              Ghost[]                @relation(name: "GhostToGamePage")
  data                Data[]                 @relation(name: "DataToGamePage")
  ratings             Rating[]               @relation(name: "RatingToGamePage")

  @@unique([gameId, version])
}

model Flag {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  icon        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  games     Game[]     @relation(name: "GamesToFlags")
  gamePages GamePage[] @relation(name: "GamePagesToFlags")
}

model RatingCategory {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String?
  askMajorityContent Boolean  @default(false)
  order              Int      @default(0)
  always             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  ratings             Rating[]   @relation("RatingToCategory")
  games               Game[]
  majContentGames     Game[]     @relation("GameToMajorityContentRating")
  gamePages           GamePage[]
  majContentGamePages GamePage[] @relation("GamePageToMajorityContentRating")
}

model TrackRatingCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  order       Int      @default(0)
  always      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratings TrackRating[] @relation("TrackRatingToCategory")
}

model TrackTagCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags TrackTag[]
}

model TrackTag {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       TrackTagCategory @relation(fields: [categoryId], references: [id])
  categoryId     Int
  gamePageTracks GamePageTrack[]
}

model TrackFlag {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gamePageTracks GamePageTrack[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category   RatingCategory @relation(fields: [categoryId], references: [id], name: "RatingToCategory")
  categoryId Int
  user       User           @relation(fields: [userId], references: [id], name: "RatingToUser")
  userId     Int
  game       Game           @relation(fields: [gameId], references: [id], name: "RatingToGame")
  gameId     Int
  gamePage   GamePage       @relation(fields: [gamePageId], references: [id], name: "RatingToGamePage")
  gamePageId Int

  @@unique([gamePageId, categoryId, userId])
}

model TrackRating {
  id        Int      @id @default(autoincrement())
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   TrackRatingCategory @relation(fields: [categoryId], references: [id], name: "TrackRatingToCategory")
  categoryId Int
  user       User                @relation(fields: [userId], references: [id], name: "TrackRatingToUser")
  userId     Int
  track      GamePageTrack       @relation(fields: [trackId], references: [id], name: "TrackRatingToTrack")
  trackId    Int

  @@unique([trackId, categoryId, userId])
}

model TrackTimestampComment {
  id        Int      @id @default(autoincrement())
  content   String
  timestamp Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User          @relation(fields: [authorId], references: [id], name: "TrackTimestampCommentToAuthor")
  authorId Int
  track    GamePageTrack @relation(fields: [trackId], references: [id], name: "TrackTimestampCommentToTrack")
  trackId  Int
}

model GamePageTrack {
  id                            Int      @id @default(autoincrement())
  slug                          String
  url                           String
  name                          String
  license                       String?
  allowDownload                 Boolean  @default(false)
  allowBackgroundUse            Boolean  @default(false)
  allowBackgroundUseAttribution Boolean  @default(false)
  bpm                           Int?
  musicalKey                    String?
  softwareUsed                  String[] @default([])
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  commentary                    String?

  composer           User                    @relation(fields: [composerId], references: [id], name: "GamePageTrackToComposer")
  composerId         Int
  gamePage           GamePage                @relation(fields: [gamePageId], references: [id], name: "TrackToGamePage")
  gamePageId         Int
  tags               TrackTag[]
  flags              TrackFlag[]
  links              GamePageTrackLink[]     @relation(name: "GamePageTrackToLinks")
  credits            GamePageTrackCredit[]   @relation(name: "GamePageTrackToCredits")
  comments           Comment[]               @relation(name: "CommentToTrack")
  ratings            TrackRating[]           @relation(name: "TrackRatingToTrack")
  notifications      Notification[]          @relation(name: "NotificationToTrack")
  timestampComments  TrackTimestampComment[] @relation(name: "TrackTimestampCommentToTrack")
  recommendedByUsers User[]                  @relation(name: "UserRecommendedTracks")

  @@unique([gamePageId, slug])
}

model GamePageTrackLink {
  id        Int      @id @default(autoincrement())
  label     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  track   GamePageTrack @relation(fields: [trackId], references: [id], name: "GamePageTrackToLinks", onDelete: Cascade)
  trackId Int
}

model GamePageTrackCredit {
  id        Int      @id @default(autoincrement())
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  track   GamePageTrack @relation(fields: [trackId], references: [id], name: "GamePageTrackToCredits", onDelete: Cascade)
  trackId Int
  user    User          @relation(fields: [userId], references: [id], name: "GamePageTrackCreditToUser")
  userId  Int
}

enum LeaderboardType {
  SCORE
  GOLF
  SPEEDRUN
  ENDURANCE
}

model GamePageLeaderboard {
  id            Int             @id @default(autoincrement())
  type          LeaderboardType
  name          String
  decimalPlaces Int             @default(0)
  maxUsersShown Int             @default(10)
  onlyBest      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  gamePage   GamePage @relation(fields: [gamePageId], references: [id], name: "LeaderboardToGamePage")
  gamePageId Int
  scores     Score[]  @relation(name: "ScoreToGamePageLeaderboard")
}

model Score {
  id        Int      @id @default(autoincrement())
  data      Int
  evidence  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user          User                @relation(fields: [userId], references: [id], name: "ScoreToUser")
  userId        Int
  leaderboard   GamePageLeaderboard @relation(fields: [leaderboardId], references: [id], name: "ScoreToGamePageLeaderboard")
  leaderboardId Int
}

model GamePageAchievement {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users      User[]   @relation(name: "GamePageAchievementToUsers")
  gamePage   GamePage @relation(fields: [gamePageId], references: [id], name: "AchievementToGamePage")
  gamePageId Int
}

model Ghost {
  id        Int      @id @default(autoincrement())
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user       User     @relation(fields: [userId], references: [id], name: "GhostToUser")
  userId     Int
  gamePage   GamePage @relation(fields: [gamePageId], references: [id], name: "GhostToGamePage")
  gamePageId Int
}

model Data {
  id        Int      @id @default(autoincrement())
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user       User     @relation(fields: [userId], references: [id], name: "DataToUser")
  userId     Int
  gamePage   GamePage @relation(fields: [gamePageId], references: [id], name: "DataToGamePage")
  gamePageId Int
}

model GameDownloadLink {
  id       Int    @id @default(autoincrement())
  url      String
  platform String // Will store: "Windows", "MacOS", "Linux", "Web", "Mobile", "Other"

  // Relation to Game
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade, name: "LinkToGame")
  gameId Int
}

model GamePageDownloadLink {
  id       Int    @id @default(autoincrement())
  url      String
  platform String

  gamePage   GamePage @relation(fields: [gamePageId], references: [id], onDelete: Cascade, name: "LinkToGamePage")
  gamePageId Int
}

model Like {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  post      Post?    @relation(fields: [postId], references: [id], name: "LikeToPost")
  postId    Int?
  comment   Comment? @relation(fields: [commentId], references: [id], name: "LikeToComment")
  commentId Int?
}

model FeaturedStreamer {
  id           Int      @id @default(autoincrement())
  userName     String
  thumbnailUrl String
  streamTitle  String
  streamTags   String[] @default([])
  viewerCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Report {
  id         Int       @id @default(autoincrement())
  resolved   Boolean   @default(false)
  status     String    @default("open")
  priority   String    @default("normal")
  reason     String?
  details    String?
  resolvedAt DateTime? @map("resolved_at")
  resolution String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  reporter            User     @relation(fields: [reporterId], references: [id], name: "ReportToReporter")
  reporterId          Int
  user                User?    @relation(fields: [userId], references: [id], name: "ReportToUser")
  userId              Int?
  post                Post?    @relation(fields: [postId], references: [id], name: "ReportToPost")
  postId              Int?
  comment             Comment? @relation(fields: [commentId], references: [id], name: "ReportToComment")
  commentId           Int?
  game                Game?    @relation(fields: [gameId], references: [id], name: "ReportToGame")
  gameId              Int?
  assignedTo          User?    @relation(fields: [assignedToId], references: [id], name: "ReportToAssignee")
  assignedToId        Int?     @map("assigned_to_id")
  collectionCommentId String?  @map("collection_comment_id")
}

enum NotificationType {
  GENERAL
  GAME_COMMENT
  TRACK_COMMENT
  COMMENT_REPLY
  POST_COMMENT
  FOLLOW
  FOLLOW_BACK
  TEAM_INVITE
