model Notification {
  id   Int              @id @default(autoincrement())
  type NotificationType

  title      String?
  body       String?
  link       String?
  data       Json?
  readAt     DateTime? @map("read_at")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // who triggered it
  actor   User? @relation(fields: [actorId], references: [id], name: "NotificationToActor")
  actorId Int?

  // who receives it
  recipient   User @relation(fields: [recipientId], references: [id], name: "NotificationToRecipient")
  recipientId Int

  // optional targets
  post              Post?            @relation(name: "post", fields: [postId], references: [id])
  postId            Int?
  comment           Comment?         @relation(name: "NotificationToComment", fields: [commentId], references: [id])
  commentId         Int?
  game              Game?            @relation(name: "NotificationToGame", fields: [gameId], references: [id])
  gameId            Int?
  track             GamePageTrack?   @relation(name: "NotificationToTrack", fields: [trackId], references: [id])
  trackId           Int?
  team              Team?            @relation(name: "team", fields: [teamId], references: [id])
  teamId            Int?
  teamInvite        TeamInvite?      @relation(name: "teamInvite", fields: [teamInviteId], references: [id])
  teamInviteId      Int?
  teamApplication   TeamApplication? @relation(name: "teamApplication", fields: [teamApplicationId], references: [id])
  teamApplicationId Int?

  @@index([type, recipientId, createdAt])
  @@index([postId])
  @@index([commentId])
  @@index([gameId])
  @@index([trackId])
  @@index([teamId])
}

